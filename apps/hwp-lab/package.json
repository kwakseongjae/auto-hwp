{
  "name": "hwp-lab",
  "version": "0.0.0",
  "private": true,
  "description": "통합 실험 앱 (issue 019): HWP 업로드 → 전 페이지 SVG 렌더 → 표 마킹 + 채팅 바이브편집(서버 프록시) → 프리뷰/적용/undo → HTML/PDF. QA 전용, tf-hwp 레포 내 독립 Next.js 앱. 루트 워크스페이스 오염 없음(file: 의존 + transpilePackages).",
  "scripts": {
    "predev": "node scripts/copy-wasm.mjs && node scripts/copy-fonts.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/copy-wasm.mjs && node scripts/copy-fonts.mjs",
    "build": "next build",
    "start": "next start",
    "fetch-fonts": "node scripts/fetch-fonts.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.109.1",
    "@tf-hwp/engine": "file:../../packages/engine",
    "@tf-hwp/react": "file:../../packages/react",
    "next": "15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.10.5",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
