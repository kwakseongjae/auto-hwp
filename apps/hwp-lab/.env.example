# auto-hwp lab — BYOK LLM 키 (바이브 편집 생성). 이 파일은 커밋되는 "템플릿"이다.
# 실제 키는 이 파일을 복사한 `.env.local`(gitignore됨)에 넣는다:  cp .env.example .env.local
# Next.js가 `.env.local`을 자동 로드한다(서버 전용 — NEXT_PUBLIC_ 접두사 없으므로 클라 번들 미포함, R6).
# 프로바이더 우선순위: OPENROUTER_API_KEY(있으면) → ANTHROPIC_API_KEY → mock(키 없으면).

# ── OpenRouter (권장, Grok) ──────────────────────────────────────────────
# https://openrouter.ai/keys 에서 발급. 키 하나로 여러 모델 라우팅.
OPENROUTER_API_KEY=

# default 모델 = x-ai/grok-4.5. 바꾸려면 정확한 OpenRouter 슬러그로 override(주석 해제).
# ("grok 4.2"는 OpenRouter에 없음 — 실제 슬러그는 grok-4.20 / grok-4.3 / grok-4.5)
# AUTO_HWP_OPENROUTER_MODEL=x-ai/grok-4.20

# ── Anthropic (폴백) ─────────────────────────────────────────────────────
# OPENROUTER_API_KEY가 없을 때만 사용(모델 claude-opus-4-8).
# ANTHROPIC_API_KEY=
