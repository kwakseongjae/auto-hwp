# tf-hwp BYOK secrets template. Copy to .env (git-ignored) and fill in.
# The launcher (scripts/app.sh) auto-loads .env before starting the desktop app.

# OpenRouter (default provider). https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional model override (any OpenRouter slug). Default: google/gemini-2.5-flash
# TF_HWP_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Optional: Anthropic direct
# ANTHROPIC_API_KEY=
