{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tf-hwp viewer",
  "version": "0.0.1",
  "identifier": "dev.tfhwp.viewer",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "cwd": "ui",
      "script": "pnpm dev"
    },
    "beforeBuildCommand": {
      "cwd": "ui",
      "script": "pnpm build"
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "tf-hwp viewer",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 },
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "HWP Document",
        "description": "Hancom HWP document",
        "ext": ["hwp"],
        "role": "Viewer",
        "mimeType": "application/x-hwp"
      },
      {
        "name": "HWPX Document",
        "description": "Hancom HWPX (OWPML) document",
        "ext": ["hwpx"],
        "role": "Editor",
        "mimeType": "application/hwp+zip"
      }
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    }
  }
}
