{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tf-hwp viewer",
  "version": "0.0.1",
  "identifier": "dev.tfhwp.viewer",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "cwd": "ui",
      "script": "pnpm dev"
    },
    "beforeBuildCommand": {
      "cwd": "ui",
      "script": "pnpm build"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "tf-hwp viewer",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 15 },
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
