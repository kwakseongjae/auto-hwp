{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@tf-hwp/react": ["../../../packages/react/dist/index.d.ts"],
      "@tf-hwp/editor-core": ["../../../packages/editor-core/dist/index.d.ts"],
      "@tf-hwp/engine": ["../../../packages/engine/index.d.ts"]
    }
  },
  "include": ["src"]
}
